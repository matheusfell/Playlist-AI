# ===== Spotify (https://developer.spotify.com/dashboard) =====
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Precisa ser EXATAMENTE igual ao Redirect URI cadastrado no dashboard do Spotify
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

# ===== Ollama (modelo de IA local, https://ollama.com) =====
# URL do servidor Ollama rodando na sua máquina
OLLAMA_URL=http://127.0.0.1:11434
# Modelo usado para gerar as músicas. Precisa ser baixado antes com: ollama pull <modelo>
OLLAMA_MODEL=llama3.2:3b

# ===== Servidor =====
PORT=3000
# Uma string aleatória qualquer para assinar os cookies de sessão
SESSION_SECRET=troque_por_uma_string_aleatoria_longa
